generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  url = env("DATABASE_URL")
  url = env("DIRECT_URL")
}


// User — stores user info, target role, resume URL
// Application — the core table, one row per job applied to
// StatusHistory — every time status changes, log it (this powers the timeline)
// AIInterview — stores AI generated questions + user's saved answers
// Reminder — follow up reminder date per application
// Account — needed by NextAuth for Google OAuth (auto required)
// Session — needed by NextAuth for session management (auto required)


model User {
id      String @id @default(cuid())
name String 
email String @unique
profilePicture String?
experienceLevel String
resumeUrl String?
createdAccountAt DateTime @default(now())
updatedAt DateTime @updatedAt
accounts Account[]
sessions Session[]
}

model Account {
  id String  @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token  String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  ASSIGNMENT
  OFFER
  REJECTED
}

enum ApplicationSource {
  LINKED_IN
  NAUKARI
  REFERAL
  COLDEMAIL
  SOCIAL_MEDIA
  OTHER_JOB_APPS
}